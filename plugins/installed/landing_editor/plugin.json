{
  "name": "Landing Page Editor",
  "slug": "landing-editor",
  "version": "1.0.0",
  "author": "CloudService Team",
  "description": "Visueller Webbaukasten fuer die oeffentliche Startseite. Nur fuer Admins sichtbar.",
  "django_app": {
    "app_config": "landing_editor.apps.LandingEditorConfig"
  },
  "hooks": {
    "ui_menu_item": {
      "handler": "landing_editor.providers.LandingEditorMenuProvider",
      "priority": 90
    },
    "ui_app_page": {
      "handler": "landing_editor.providers.LandingEditorPageProvider",
      "priority": 90,
      "slug": "landing-editor"
    }
  },
  "settings": {
    "has_settings": false
  }
}
