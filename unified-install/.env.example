# ==============================================
# Django Platform - Environment Configuration
# ==============================================
# Copy this file to .env and customize for your environment

# ==================== Database ====================
# MariaDB root password (generated during setup, change in production!)
DB_ROOT_PASSWORD=your_secure_root_password_here

# Application database user
DB_USER=platform_user
DB_PASSWORD=your_secure_db_password_here

# ==================== JWT/SSO ====================
# Secret key for JWT signing (must be same across all apps!)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
JWT_SECRET_KEY=your_long_random_secret_key_min_256_bits

# SSO Cookie Configuration
# For subdomains: SSO_COOKIE_DOMAIN=.yourdomain.com
# For localhost: SSO_COOKIE_DOMAIN=.localhost
# For path-based: SSO_COOKIE_DOMAIN=None
SSO_COOKIE_DOMAIN=.localhost

# ==================== Cloude Settings ====================
CLOUDE_DEBUG=False
CLOUDE_SECRET_KEY=cloude_specific_django_secret_key_here
CLOUDE_ALLOWED_HOSTS=cloude.localhost,localhost,127.0.0.1

# ==================== HelpDesk Settings ====================
HELPDESK_DEBUG=False
HELPDESK_SECRET_KEY=helpdesk_specific_django_secret_key_here
HELPDESK_ALLOWED_HOSTS=helpdesk.localhost,localhost,127.0.0.1

# ==================== Email Settings ====================
# SMTP Configuration (Office365/Outlook example)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@company.com
EMAIL_HOST_PASSWORD=your-email-password

# IMAP Configuration (for reading emails)
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USERNAME=your-email@company.com
IMAP_PASSWORD=your-email-password
IMAP_ENABLED=False

# ==================== Optional Settings ====================

# HelpDesk-specific
# MICROSOFT_CLIENT_ID=your_client_id
# MICROSOFT_CLIENT_SECRET=your_secret
# MICROSOFT_TENANT_ID=your_tenant_id
# MICROSOFT_REDIRECT_URI=http://localhost:8100/auth/microsoft/callback

# Claude AI (for HelpDesk AI features)
# CLAUDE_API_KEY=your_claude_api_key

# Teams Integration
# TEAMS_WEBHOOK_URL=your_teams_webhook_url

# Sentry Error Tracking
# SENTRY_DSN=your_sentry_dsn

# Redis URL (auto-configured in Docker Compose)
# REDIS_URL=redis://localhost:6379/0

# ==================== Deployment Configuration ====================

# Set to True in production
HTTPS_ENABLED=False

# Site URL for links in emails
SITE_URL=http://localhost

# Language and timezone
LANGUAGE_CODE=de-de
TIME_ZONE=Europe/Berlin

# Auto-update configuration
AUTO_UPDATE=False
AUTO_UPDATE_HOUR=2

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Allowed iframe origins (for chat widget, etc.)
ALLOWED_IFRAME_ORIGINS=http://localhost,http://127.0.0.1

# ==================== Multi-tenant Branding ====================
APP_NAME=Django Platform
COMPANY_NAME=Your Company
APP_TITLE=Django Platform
# LOGO_URL=/static/images/logo.png
